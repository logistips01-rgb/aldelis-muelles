rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Version de la app (interruptor de auto-actualizacion).
    match /config/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /reservas/{id} {
      // Lectura: abierta de momento (la consulta publica y el calculo de
      // franjas la necesitan). Se cierra en la Fase 2 con App Check.
      allow read: if true;

      // Crear: solo reservas con formato valido y estado inicial controlado.
      allow create: if validReserva();

      // Modificar / borrar: solo personal autenticado (almacen).
      allow update, delete: if request.auth != null;
    }

    // Estado en vivo de las lanzaderas (una doc por lanzadera, id "1".."4").
    // App Check ya restringe la escritura a la propia web.
    match /lanzaderas/{id} {
      allow read: if true;
      allow create, update: if validLanzadera();
    }

    // Historico de movimientos (para informes). Solo se anade, no se edita.
    match /lanzaderas_log/{id} {
      allow read: if request.auth != null;
      allow create: if validLanzadera();
    }

    // Indicaciones para las lanzaderas (una doc por lanzadera). El conductor
    // las lee al salir; el almacen las escribe; el conductor las limpia.
    match /lanzaderas_nota/{id} {
      allow read: if true;
      allow create, update: if validNota();
    }

    function validNota() {
      let d = request.resource.data;
      return d.numero is number && d.numero >= 1 && d.numero <= 4
        && d.nota is string && d.nota.size() <= 200;
    }

    // Cargas (registro al momento en muelles de carga M1-M5).
    // Lectura solo almacen (incluye DNI). Crear: transportista o almacen.
    match /cargas/{id} {
      allow read: if request.auth != null;
      allow create: if validCarga();
      allow update, delete: if request.auth != null;
    }

    function validCarga() {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'matricula_tractora','matricula_semi','chofer','dni',
          'destino','muelle','estado','inicio','fin','created_at'
        ])
        && d.estado == 'cargando'
        && d.fin == null
        && d.muelle in ['M1','M2','M3','M4','M5']
        && d.matricula_tractora is string && d.matricula_tractora.size() > 0 && d.matricula_tractora.size() <= 20
        && d.matricula_semi is string && d.matricula_semi.size() <= 20
        && d.chofer is string && d.chofer.size() <= 120
        && d.dni is string && d.dni.size() <= 20
        && d.destino is string && d.destino.size() <= 120;
    }

    function validLanzadera() {
      let d = request.resource.data;
      return d.numero is number && d.numero >= 1 && d.numero <= 4
        && d.estado in ['en_nave', 'transito', 'fuera']
        && d.nave in ['caserfri','merca','arento','avitrans','txt','upasa','plaza']
        && d.accion in ['presente','cargando','descargando']
        && (d.muelle == null || (d.muelle is string && d.muelle.size() <= 10))
        && (d.destino == null || d.destino in ['caserfri','merca','arento','avitrans','txt','upasa','plaza'])
        && d.activa is bool;
    }

    function validReserva() {
      let d = request.resource.data;
      return
        // Solo se admiten exactamente estos campos
        d.keys().hasOnly([
          'codigo','matricula','empresa','conductor','email','temperatura',
          'seccion','mercancia','pales','peso','observaciones','franja',
          'fecha','estado','muelle','nota_almacen','motivo','created_at'
        ])
        // El que reserva no puede auto-confirmarse ni asignarse muelle
        && d.estado == 'pendiente'
        && d.muelle == null
        && d.nota_almacen == ''
        && d.motivo == ''
        // Seccion valida
        && d.seccion in ['seco','frio','lavadero']
        // Campos obligatorios con limite de longitud
        && d.matricula is string && d.matricula.size() > 0 && d.matricula.size() <= 20
        && d.empresa   is string && d.empresa.size()   > 0 && d.empresa.size()   <= 120
        && d.codigo    is string && d.codigo.size()    <= 40
        && d.franja    is string && d.franja.size()    <= 20
        && d.fecha     is string && d.fecha.size()     <= 10
        // Campos opcionales con tope de longitud
        && d.conductor     is string && d.conductor.size()     <= 120
        && d.email         is string && d.email.size()         <= 160
        && d.mercancia     is string && d.mercancia.size()     <= 300
        && d.observaciones is string && d.observaciones.size() <= 500
        && d.temperatura   is string && d.temperatura.size()   <= 20
        // Numericos: numero o nulo
        && (d.pales == null || d.pales is number)
        && (d.peso  == null || d.peso  is number);
    }
  }
}
